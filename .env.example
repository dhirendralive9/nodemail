# ╔══════════════════════════════════════════╗
# ║        NodeMail — Configuration          ║
# ╚══════════════════════════════════════════╝
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env && nano .env

# ── App ──
PORT=3000
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# ── MongoDB ──
MONGO_URI=mongodb://127.0.0.1:27017/nodemail

# ── Outbound SMTP (your email sending provider) ──
# Works with Brevo, Mailgun, SendGrid, SES, or any SMTP server
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-login
SMTP_PASS=your-smtp-api-key

# ── Inbound Email ──
# "smtp" = built-in SMTP server on port 25 (requires MX records)
# "webhook" = HTTP POST from external provider (Mailgun, SendGrid, etc.)
INBOUND_MODE=smtp
INBOUND_SMTP_PORT=25

# ── Default Admin Account (created on first run) ──
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASS=changeme123

# ── Server Identity ──
# Must match your SSL certificate and DNS records
MAIL_HOSTNAME=mail.yourdomain.com
SERVER_IP=

# ── SMTP Relay for Mail Clients (Thunderbird/Outlook) ──
# Users authenticate with their NodeMail credentials
SMTP_RELAY_PORT=587

# ── IMAP (Dovecot) ──
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
VMAIL_DIR=/var/vmail

# ── Cloudflare Turnstile (optional — leave blank to disable) ──
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── IP Ban / Rate Limiting ──
LOGIN_MAX_FAILURES=5
LOGIN_BAN_WINDOW=15
LOGIN_BAN_DURATION=30

# ── Spam Filter (SPF/DKIM/DMARC verification) ──
# Set SPAM_FILTER=false to disable entirely
# Policy per check: "reject" | "flag" | "allow"
SPAM_FILTER=true
SPAM_SPF_POLICY=flag
SPAM_DKIM_POLICY=flag
SPAM_DMARC_POLICY=flag

# ── Custom TLS Certificate Path (optional) ──
# Override auto-detection of Let's Encrypt certs
# TLS_CERT_PATH=/etc/letsencrypt/live/mail.yourdomain.com
