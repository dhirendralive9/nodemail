# ── App ──
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# ── MongoDB ──
MONGO_URI=mongodb://127.0.0.1:27017/nodemail

# ── Outbound SMTP (generic — works with Brevo, Mailgun, SES, etc.) ──
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# ── Inbound Mode: "smtp" (built-in SMTP server) or "webhook" (HTTP POST) ──
INBOUND_MODE=smtp

# ── Built-in SMTP server (only used when INBOUND_MODE=smtp) ──
INBOUND_SMTP_PORT=25

# ── Default admin account (created on first run) ──
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASS=changeme123
