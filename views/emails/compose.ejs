<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NodeMail — Compose</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="app">
    <%- include('../partials/sidebar') %>

    <div class="main">
      <div class="toolbar">
        <button class="sidebar-toggle" onclick="toggleSidebar()">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
        <a href="/" class="btn btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back
        </a>
        <span class="toolbar-title" style="margin-left:8px;">Compose</span>
      </div>

      <div class="compose-form">
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>

        <% if (typeof mailboxes !== 'undefined' && mailboxes.length === 0) { %>
          <div class="error-msg">
            No mailboxes available. <a href="/mailboxes">Create a mailbox</a> first.
          </div>
        <% } %>

        <form method="POST" action="/send" enctype="multipart/form-data">
          <input type="hidden" name="inReplyTo" value="<%= prefill.inReplyTo %>">
          <input type="hidden" name="references" value="<%= prefill.references %>">

          <div class="form-row">
            <label>From</label>
            <% if (typeof mailboxes !== 'undefined' && mailboxes.length > 0) { %>
              <select name="fromAddress" class="form-select">
                <% mailboxes.forEach(function(mb) { %>
                  <option value="<%= mb.address %>" <%= (prefill.fromAddress === mb.address) ? 'selected' : '' %>>
                    <%= mb.displayName ? mb.displayName + ' <' + mb.address + '>' : mb.address %>
                  </option>
                <% }); %>
              </select>
            <% } else { %>
              <input type="text" value="<%= session.userEmail %>" disabled>
              <input type="hidden" name="fromAddress" value="">
            <% } %>
          </div>

          <div class="form-row">
            <label>To</label>
            <input type="text" name="to" placeholder="recipient@example.com" value="<%= prefill.to %>" required>
          </div>

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
            <div class="form-row">
              <label>CC</label>
              <input type="text" name="cc" placeholder="Optional" value="<%= prefill.cc || '' %>">
            </div>
            <div class="form-row">
              <label>BCC</label>
              <input type="text" name="bcc" placeholder="Optional" value="<%= prefill.bcc || '' %>">
            </div>
          </div>

          <div class="form-row">
            <label>Subject</label>
            <input type="text" name="subject" placeholder="Subject" value="<%= prefill.subject %>">
          </div>

          <div class="form-row">
            <label>Message</label>
            <textarea name="body" placeholder="Write your message..."><%= prefill.body %></textarea>
          </div>

          <div class="form-row">
            <label>Attachments</label>
            <input type="file" name="attachments" multiple>
          </div>

          <div style="display:flex;gap:8px;margin-top:8px;">
            <button type="submit" class="btn btn-primary" <%= (typeof mailboxes !== 'undefined' && mailboxes.length === 0) ? 'disabled' : '' %>>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
              Send
            </button>
            <a href="/" class="btn">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
