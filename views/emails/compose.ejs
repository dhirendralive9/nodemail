<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NodeMail — Compose</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="app">
    <%- include('../partials/sidebar') %>

    <div class="main">
      <div class="toolbar">
        <a href="/" class="btn btn-sm">&larr; Back</a>
        <span class="toolbar-title" style="margin-left:12px;">Compose Email</span>
      </div>

      <div class="compose-form">
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>

        <% if (typeof mailboxes !== 'undefined' && mailboxes.length === 0) { %>
          <div class="error-msg" style="margin-bottom:20px;">
            No mailboxes available. <a href="/mailboxes" style="color:#f87171;">Create a mailbox</a> first to send emails.
          </div>
        <% } %>

        <form method="POST" action="/send" enctype="multipart/form-data">
          <input type="hidden" name="inReplyTo" value="<%= prefill.inReplyTo %>">
          <input type="hidden" name="references" value="<%= prefill.references %>">

          <!-- FROM selector -->
          <div class="form-row">
            <label>From</label>
            <% if (typeof mailboxes !== 'undefined' && mailboxes.length > 0) { %>
              <select name="fromAddress" class="form-select">
                <% mailboxes.forEach(function(mb) { %>
                  <option value="<%= mb.address %>"
                    <%= (prefill.fromAddress === mb.address) ? 'selected' : '' %>>
                    <%= mb.displayName ? mb.displayName + ' <' + mb.address + '>' : mb.address %>
                  </option>
                <% }); %>
              </select>
            <% } else { %>
              <input type="text" value="<%= session.userName %> <<%= session.userEmail %>>" disabled>
              <input type="hidden" name="fromAddress" value="">
            <% } %>
          </div>

          <div class="form-row">
            <label>To</label>
            <input type="text" name="to" placeholder="recipient@example.com" value="<%= prefill.to %>" required>
          </div>

          <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
            <div class="form-row">
              <label>CC</label>
              <input type="text" name="cc" placeholder="cc@example.com" value="<%= prefill.cc || '' %>">
            </div>
            <div class="form-row">
              <label>BCC</label>
              <input type="text" name="bcc" placeholder="bcc@example.com" value="<%= prefill.bcc || '' %>">
            </div>
          </div>

          <div class="form-row">
            <label>Subject</label>
            <input type="text" name="subject" placeholder="Email subject" value="<%= prefill.subject %>">
          </div>

          <div class="form-row">
            <label>Message</label>
            <textarea name="body" placeholder="Write your message..."><%= prefill.body %></textarea>
          </div>

          <div class="form-row">
            <label>Attachments (max 25 MB each)</label>
            <input type="file" name="attachments" multiple>
          </div>

          <div style="display:flex;gap:10px;margin-top:8px;">
            <button type="submit" class="btn btn-primary" <%= (typeof mailboxes !== 'undefined' && mailboxes.length === 0) ? 'disabled' : '' %>>Send Email</button>
            <a href="/" class="btn">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
