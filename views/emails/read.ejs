<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NodeMail — <%= email.subject %></title>
  <link rel="stylesheet" href="/css/style.css?v=<%= v %>">
</head>
<body>
  <div class="app">
    <%- include('../partials/sidebar') %>

    <div class="main">
      <div class="toolbar">
        <button class="sidebar-toggle" onclick="toggleSidebar()">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
        <a href="/?folder=<%= email.folder %>" class="btn btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back
        </a>
        <div class="toolbar-spacer"></div>
        <form method="POST" action="/email/<%= email._id %>/star" style="display:inline">
          <button type="submit" class="btn btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="<%= email.starred ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <%= email.starred ? 'Unstar' : 'Star' %>
          </button>
        </form>
        <form method="POST" action="/email/<%= email._id %>/toggle-read" style="display:inline">
          <button type="submit" class="btn btn-sm"><%= email.read ? 'Mark unread' : 'Mark read' %></button>
        </form>
      </div>

      <div class="email-reader">
        <h1><%= email.subject %></h1>

        <div class="email-meta">
          <div>
            <strong>From</strong>
            <% if (email.fromName) { %>
              <%= email.fromName %> &lt;<%= email.from %>&gt;
            <% } else { %>
              <%= email.from %>
            <% } %>
          </div>
          <div><strong>To</strong> <%= email.to.join(', ') %></div>
          <% if (email.cc && email.cc.length > 0 && email.cc[0]) { %>
            <div><strong>CC</strong> <%= email.cc.join(', ') %></div>
          <% } %>
          <div><strong>Date</strong> <%= new Date(email.date).toLocaleString() %></div>
        </div>

        <div class="email-body">
          <% if (email.htmlBody && email.htmlBody.trim()) { %>
            <%
              var darkStyle = '<style>body{background:#1c1c1c!important;color:#d4d4d4!important;font-family:IBM Plex Sans,-apple-system,sans-serif;padding:16px;margin:0;font-size:14px;line-height:1.7;}a{color:#f59e0b!important;}img{max-width:100%;height:auto;}table{border-collapse:collapse;}td,th{border:1px solid #2e2e2e;padding:6px 10px;}</style>';
              var safeHtml = darkStyle + email.htmlBody;
            %>
            <iframe
              srcdoc="<%- safeHtml.replace(/"/g, '&quot;') %>"
              sandbox="allow-same-origin"
              style="width:100%;border:1px solid var(--border);border-radius:var(--radius);min-height:300px;background:#1c1c1c;"
              onload="this.style.height = Math.max(300, this.contentWindow.document.body.scrollHeight + 40) + 'px'"
            ></iframe>
          <% } else if (email.textBody && email.textBody.trim()) { %>
            <pre class="text-body"><%= email.textBody %></pre>
          <% } else { %>
            <p style="color:var(--text-muted);font-style:italic;">No message content</p>
          <% } %>
        </div>

        <% if (email.attachments && email.attachments.length > 0) { %>
          <div class="att-list">
            <h3>Attachments (<%= email.attachments.length %>)</h3>
            <% email.attachments.forEach(function(att) { %>
              <a href="/attachment/<%= email._id %>/<%= att._id %>" class="att-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                <%= att.filename %>
                <span style="color:var(--text-muted);">(<%= (att.size / 1024).toFixed(1) %>K)</span>
              </a>
            <% }); %>
          </div>
        <% } %>

        <div class="email-actions">
          <a href="/reply/<%= email._id %>" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>
            Reply
          </a>
          <a href="/forward/<%= email._id %>" class="btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 17 20 12 15 7"/><path d="M4 18v-2a4 4 0 0 1 4-4h12"/></svg>
            Forward
          </a>

          <form method="POST" action="/email/<%= email._id %>/move" style="display:inline-flex;align-items:center;gap:4px;">
            <select name="folder" class="form-select" style="width:auto;padding:6px 28px 6px 8px;font-size:11px;">
              <option value="inbox">Inbox</option>
              <option value="drafts">Drafts</option>
              <option value="trash">Trash</option>
              <% if (sidebar.customFolders) { sidebar.customFolders.forEach(function(cf) { %>
                <option value="<%= cf._id %>"><%= cf.name %></option>
              <% }); } %>
            </select>
            <button type="submit" class="btn btn-sm">Move</button>
          </form>

          <form method="POST" action="/email/<%= email._id %>/delete" style="display:inline">
            <input type="hidden" name="returnFolder" value="<%= email.folder %>">
            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('<%= email.folder === "trash" ? "Permanently delete?" : "Move to trash?" %>')">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
              Delete
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/app.js?v=<%= v %>"></script>
</body>
</html>
