<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Email Sender</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0f1117;
      color: #e4e4e7;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: #1a1b23;
      border: 1px solid #2a2b35;
      border-radius: 12px;
      padding: 40px;
      width: 100%;
      max-width: 520px;
    }
    h1 {
      font-size: 22px;
      font-weight: 600;
      margin-bottom: 6px;
    }
    .sub {
      color: #71717a;
      font-size: 14px;
      margin-bottom: 28px;
    }
    label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: #a1a1aa;
      margin-bottom: 6px;
    }
    input, textarea {
      width: 100%;
      padding: 10px 14px;
      background: #0f1117;
      border: 1px solid #2a2b35;
      border-radius: 8px;
      color: #e4e4e7;
      font-size: 14px;
      font-family: inherit;
      margin-bottom: 18px;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus, textarea:focus {
      border-color: #3b82f6;
    }
    textarea { resize: vertical; min-height: 120px; }
    button {
      width: 100%;
      padding: 12px;
      background: #3b82f6;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }
    button:hover { background: #2563eb; }
    .alert {
      margin-top: 18px;
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 13px;
      line-height: 1.5;
      word-break: break-all;
    }
    .alert.ok  { background: #052e16; border: 1px solid #166534; color: #4ade80; }
    .alert.err { background: #2a0a0a; border: 1px solid #7f1d1d; color: #f87171; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Send Email</h1>
    <p class="sub">Via Brevo SMTP &middot; Nodemailer</p>

    <form method="POST" action="/send">
      <label for="to">To</label>
      <input type="email" id="to" name="to" placeholder="recipient@example.com" required />

      <label for="subject">Subject</label>
      <input type="text" id="subject" name="subject" placeholder="Email subject" required />

      <label for="body">Message</label>
      <textarea id="body" name="body" placeholder="Write your message..." required></textarea>

      <button type="submit">Send Email</button>
    </form>

    <% if (result) { %>
      <div class="alert <%= result.ok ? 'ok' : 'err' %>">
        <%= result.msg %>
      </div>
    <% } %>
  </div>
</body>
</html>
