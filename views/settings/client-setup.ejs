<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NodeMail — Mail Client Setup</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .config-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      margin: 12px 0;
    }
    .config-table td {
      padding: 8px 12px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    .config-table td:first-child {
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      width: 160px;
      white-space: nowrap;
    }
    .config-value {
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--accent-h);
      user-select: all;
    }
    .copy-btn {
      background: var(--bg-hover);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 10px;
      padding: 3px 8px;
      cursor: pointer;
      margin-left: 8px;
      transition: all 0.1s;
    }
    .copy-btn:hover { background: var(--accent-dim); color: var(--accent-h); }
    .copy-btn.copied { background: var(--green-dim); color: #86efac; }
    .client-tabs {
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 0;
    }
    .client-tab {
      padding: 10px 18px;
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: all 0.1s;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
    }
    .client-tab:hover { color: var(--text); }
    .client-tab.active { color: var(--accent-h); border-bottom-color: var(--accent); }
    .client-panel { display: none; padding: 20px; }
    .client-panel.active { display: block; }
    .cmd-block {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 14px 16px;
      margin: 12px 0;
      font-family: var(--font-mono);
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-dim);
      overflow-x: auto;
      position: relative;
    }
    .cmd-block .comment { color: var(--text-muted); }
    .cmd-block .cmd { color: var(--accent-h); }
    .step-list {
      counter-reset: steps;
      list-style: none;
      padding: 0;
    }
    .step-list li {
      counter-increment: steps;
      padding: 8px 0 8px 36px;
      position: relative;
      font-size: 13px;
      color: var(--text-dim);
      line-height: 1.6;
      border-bottom: 1px solid var(--border);
    }
    .step-list li:last-child { border-bottom: none; }
    .step-list li::before {
      content: counter(steps);
      position: absolute;
      left: 0;
      width: 24px;
      height: 24px;
      background: var(--accent-dim);
      color: var(--accent-h);
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 600;
    }
    .account-select {
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include('../partials/sidebar') %>

    <div class="main">
      <div class="toolbar">
        <button class="sidebar-toggle" onclick="toggleSidebar()">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
        <span class="toolbar-title">Mail Client Setup</span>
      </div>

      <div class="settings-page">

        <!-- Account selector -->
        <div class="settings-card">
          <h2>Your Mailboxes</h2>
          <p class="card-desc">Use these credentials to connect any email app. Your login email and password are the same as your NodeMail web login.</p>

          <% if (mailboxes.length === 0) { %>
            <div class="error-msg">No mailboxes assigned. Ask your admin to assign a mailbox to your account.</div>
          <% } else { %>
            <div class="account-select">
              <label class="form-row" style="margin-bottom:6px;">
                <label>Select mailbox to configure</label>
              </label>
              <select class="form-select" id="mailboxSelect" onchange="updateConfig()" style="max-width:400px;">
                <% mailboxes.forEach(function(mb, i) { %>
                  <option value="<%= mb.address %>" data-display="<%= mb.displayName || mb.localPart %>"><%= mb.address %><%= mb.displayName ? ' (' + mb.displayName + ')' : '' %></option>
                <% }); %>
              </select>
            </div>
          <% } %>
        </div>

        <!-- Connection settings -->
        <div class="settings-card" style="padding:0;overflow:hidden;">
          <h2 style="padding:16px 20px 0;">Connection Settings</h2>

          <!-- Incoming mail -->
          <div style="padding:0 20px;">
            <div class="section" style="margin-top:12px;">
              <div class="section-header">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
                Incoming Mail (IMAP)
              </div>
              <div class="section-body">
                <table class="config-table">
                  <tr>
                    <td>Protocol</td>
                    <td><span class="config-value">IMAP</span></td>
                  </tr>
                  <tr>
                    <td>Server</td>
                    <td><span class="config-value" id="imapServer"><%= imapHost %></span> <button class="copy-btn" onclick="copyVal('imapServer', this)">Copy</button></td>
                  </tr>
                  <tr>
                    <td>Port</td>
                    <td><span class="config-value" id="imapPort"><%= imapPort %></span> <button class="copy-btn" onclick="copyVal('imapPort', this)">Copy</button></td>
                  </tr>
                  <tr>
                    <td>Security</td>
                    <td><span class="config-value">SSL/TLS</span></td>
                  </tr>
                  <tr>
                    <td>Username</td>
                    <td><span class="config-value" id="imapUser"><%= session.userEmail %></span> <button class="copy-btn" onclick="copyVal('imapUser', this)">Copy</button></td>
                  </tr>
                  <tr>
                    <td>Password</td>
                    <td><span class="config-value">Your NodeMail password</span></td>
                  </tr>
                </table>
              </div>
            </div>
          </div>

          <!-- Outgoing mail -->
          <div style="padding:0 20px 20px;">
            <div class="section">
              <div class="section-header">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
                Outgoing Mail (SMTP)
              </div>
              <div class="section-body">
                <table class="config-table">
                  <tr>
                    <td>Protocol</td>
                    <td><span class="config-value">SMTP</span></td>
                  </tr>
                  <tr>
                    <td>Server</td>
                    <td><span class="config-value" id="smtpServer"><%= hostname %></span> <button class="copy-btn" onclick="copyVal('smtpServer', this)">Copy</button></td>
                  </tr>
                  <tr>
                    <td>Port</td>
                    <td><span class="config-value" id="smtpPort"><%= smtpRelayPort %></span> <button class="copy-btn" onclick="copyVal('smtpPort', this)">Copy</button></td>
                  </tr>
                  <tr>
                    <td>Security</td>
                    <td><span class="config-value">STARTTLS</span></td>
                  </tr>
                  <tr>
                    <td>Authentication</td>
                    <td><span class="config-value">Normal password</span></td>
                  </tr>
                  <tr>
                    <td>Username</td>
                    <td><span class="config-value" id="smtpUser"><%= session.userEmail %></span> <button class="copy-btn" onclick="copyVal('smtpUser', this)">Copy</button></td>
                  </tr>
                  <tr>
                    <td>Password</td>
                    <td><span class="config-value">Your NodeMail password</span></td>
                  </tr>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Per-client instructions -->
        <div class="settings-card" style="padding:0;overflow:hidden;">
          <div class="client-tabs">
            <button class="client-tab active" onclick="showTab('thunderbird', this)">Thunderbird</button>
            <button class="client-tab" onclick="showTab('outlook', this)">Outlook</button>
            <button class="client-tab" onclick="showTab('apple', this)">Apple Mail / iOS</button>
            <button class="client-tab" onclick="showTab('android', this)">Android</button>
          </div>

          <div class="client-panel active" id="tab-thunderbird">
            <h3 style="font-size:14px;margin-bottom:12px;">Mozilla Thunderbird</h3>
            <ol class="step-list">
              <li>Open Thunderbird and go to <strong>Account Settings</strong> (hamburger menu &rarr; Account Settings)</li>
              <li>Click <strong>Account Actions</strong> &rarr; <strong>Add Mail Account</strong></li>
              <li>Enter your name, email address (<span class="config-value" style="font-size:12px;" id="tbEmail"></span>), and NodeMail password</li>
              <li>Click <strong>Configure manually</strong> and enter the settings above:
                <br>Incoming: <strong>IMAP</strong>, Server: <strong><%= imapHost %></strong>, Port: <strong><%= imapPort %></strong>, SSL: <strong>SSL/TLS</strong>
                <br>Outgoing: <strong>SMTP</strong>, Server: <strong><%= hostname %></strong>, Port: <strong><%= smtpRelayPort %></strong>, SSL: <strong>STARTTLS</strong>
              </li>
              <li>Set authentication to <strong>Normal password</strong> for both</li>
              <li>Click <strong>Re-test</strong> then <strong>Done</strong></li>
            </ol>
            <% if (mailboxes.length > 1) { %>
              <div class="guide-note" style="margin-top:16px;">
                <strong>Multiple mailboxes:</strong> You have <%= mailboxes.length %> mailboxes. To send from any of them:
                <br>Go to <strong>Account Settings</strong> &rarr; select your account &rarr; <strong>Manage Identities</strong> &rarr; <strong>Add</strong>
                <br>Add each mailbox address as a separate identity:
                <% mailboxes.forEach(function(mb) { %>
                  <br>&bull; <code><%= mb.address %></code><%= mb.displayName ? ' (' + mb.displayName + ')' : '' %>
                <% }); %>
                <br>When composing, the "From" dropdown will show all identities.
              </div>
            <% } %>
          </div>

          <div class="client-panel" id="tab-outlook">
            <h3 style="font-size:14px;margin-bottom:12px;">Microsoft Outlook</h3>
            <ol class="step-list">
              <li>Open Outlook and go to <strong>File</strong> &rarr; <strong>Add Account</strong></li>
              <li>Enter your email address and click <strong>Advanced options</strong> &rarr; check <strong>Let me set up my account manually</strong></li>
              <li>Select <strong>IMAP</strong></li>
              <li>Enter incoming mail settings:
                <br>Server: <strong><%= imapHost %></strong>, Port: <strong><%= imapPort %></strong>, Encryption: <strong>SSL/TLS</strong>
              </li>
              <li>Enter outgoing mail settings:
                <br>Server: <strong><%= hostname %></strong>, Port: <strong><%= smtpRelayPort %></strong>, Encryption: <strong>STARTTLS</strong>
              </li>
              <li>Enter your NodeMail password and click <strong>Connect</strong></li>
            </ol>
            <% if (mailboxes.length > 1) { %>
              <div class="guide-note" style="margin-top:16px;">
                <strong>Multiple mailboxes:</strong> In Outlook desktop:
                <br>Go to <strong>File</strong> &rarr; <strong>Account Settings</strong> &rarr; select your account &rarr; <strong>Change</strong> &rarr; <strong>More Settings</strong>
                <br>Under the <strong>General</strong> tab, you can change the reply address. For multiple From addresses, add each as a separate account using the same IMAP/SMTP settings but with a different email address:
                <% mailboxes.forEach(function(mb) { %>
                  <br>&bull; <code><%= mb.address %></code>
                <% }); %>
                <br>Use the same login credentials (<code><%= session.userEmail %></code>) for all accounts.
              </div>
            <% } %>
          </div>

          <div class="client-panel" id="tab-apple">
            <h3 style="font-size:14px;margin-bottom:12px;">Apple Mail / iPhone / iPad</h3>
            <ol class="step-list">
              <li><strong>iPhone/iPad:</strong> Go to <strong>Settings</strong> &rarr; <strong>Mail</strong> &rarr; <strong>Accounts</strong> &rarr; <strong>Add Account</strong> &rarr; <strong>Other</strong> &rarr; <strong>Add Mail Account</strong>
                <br><strong>Mac:</strong> Open Mail &rarr; <strong>Mail</strong> menu &rarr; <strong>Add Account</strong> &rarr; <strong>Other Mail Account</strong>
              </li>
              <li>Enter your name, email address, and password</li>
              <li>Select <strong>IMAP</strong> when prompted</li>
              <li>Incoming mail server: <strong><%= imapHost %></strong>
                <br>Outgoing mail server: <strong><%= hostname %></strong>
              </li>
              <li>Username: <strong><%= session.userEmail %></strong> (for both incoming and outgoing)</li>
              <li>Tap <strong>Next</strong> — iOS will auto-detect ports and SSL settings</li>
            </ol>
            <% if (mailboxes.length > 1) { %>
              <div class="guide-note" style="margin-top:16px;">
                <strong>Multiple mailboxes:</strong>
                <br><strong>Mac:</strong> Open Mail &rarr; <strong>Settings</strong> &rarr; <strong>Accounts</strong> &rarr; select your account &rarr; <strong>Email Addresses</strong> field. Add aliases separated by commas:
                <br><code><%= mailboxes.map(function(mb) { return mb.address; }).join(', ') %></code>
                <br><strong>iOS:</strong> Go to <strong>Settings</strong> &rarr; <strong>Mail</strong> &rarr; <strong>Accounts</strong> &rarr; select the account &rarr; <strong>Account</strong> &rarr; <strong>Email</strong> &rarr; <strong>Add Another Email</strong>. Add each address. When composing, tap the From field to switch.
              </div>
            <% } %>
          </div>

          <div class="client-panel" id="tab-android">
            <h3 style="font-size:14px;margin-bottom:12px;">Android (Gmail App / K-9 Mail)</h3>
            <ol class="step-list">
              <li>Open <strong>Gmail</strong> app &rarr; tap your avatar &rarr; <strong>Add another account</strong> &rarr; <strong>Other</strong></li>
              <li>Enter your email address and tap <strong>Next</strong></li>
              <li>Select <strong>IMAP</strong> (not Personal/POP3)</li>
              <li>Incoming server settings:
                <br>Server: <strong><%= imapHost %></strong>, Port: <strong><%= imapPort %></strong>, Security: <strong>SSL/TLS</strong>
              </li>
              <li>Outgoing server settings:
                <br>Server: <strong><%= hostname %></strong>, Port: <strong><%= smtpRelayPort %></strong>, Security: <strong>STARTTLS</strong>
              </li>
              <li>Enter your NodeMail password for both and tap <strong>Next</strong></li>
            </ol>
            <% if (mailboxes.length > 1) { %>
              <div class="guide-note" style="margin-top:16px;">
                <strong>Multiple mailboxes:</strong> Gmail app doesn't support aliases natively.
                <br>Add each mailbox as a <strong>separate account</strong> using the same login (<code><%= session.userEmail %></code>) but with a different email address:
                <% mailboxes.forEach(function(mb) { %>
                  <br>&bull; <code><%= mb.address %></code>
                <% }); %>
                <br>When composing, switch between accounts using the From field.
                <br><br><strong>K-9 Mail / FairEmail:</strong> These support identities natively. Go to Account Settings &rarr; Identities &rarr; add each mailbox address.
              </div>
            <% } %>
          </div>
        </div>

        <!-- Server setup (Dovecot) -->
        <div class="settings-card">
          <h2>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="vertical-align:-2px;margin-right:4px;"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/></svg>
            Server Setup (Admin)
          </h2>
          <p class="card-desc">
            For IMAP access, you need Dovecot installed on your server. The outbound SMTP relay is built into NodeMail (port <%= smtpRelayPort %>).
          </p>

          <h3 style="font-size:13px;margin: 16px 0 8px;font-family:var(--font-mono);color:var(--text-dim);">1. Install Dovecot</h3>
          <div class="cmd-block">
<span class="comment"># Install Dovecot IMAP server</span>
<span class="cmd">sudo apt install -y dovecot-imapd</span>

<span class="comment"># Enable and start</span>
<span class="cmd">sudo systemctl enable dovecot</span>
<span class="cmd">sudo systemctl start dovecot</span>
          </div>

          <h3 style="font-size:13px;margin: 16px 0 8px;font-family:var(--font-mono);color:var(--text-dim);">2. Configure Dovecot for NodeMail</h3>
          <p class="card-desc">Edit <code>/etc/dovecot/conf.d/10-mail.conf</code> to use Maildir:</p>
          <div class="cmd-block">
<span class="cmd">mail_location = maildir:~/Maildir</span>
          </div>

          <p class="card-desc" style="margin-top:12px;">Edit <code>/etc/dovecot/conf.d/10-ssl.conf</code> for SSL (use your Let's Encrypt certs):</p>
          <div class="cmd-block">
<span class="cmd">ssl = required</span>
<span class="cmd">ssl_cert = &lt;/etc/letsencrypt/live/<%= hostname %>/fullchain.pem</span>
<span class="cmd">ssl_key = &lt;/etc/letsencrypt/live/<%= hostname %>/privkey.pem</span>
          </div>

          <h3 style="font-size:13px;margin: 16px 0 8px;font-family:var(--font-mono);color:var(--text-dim);">3. Create system users for each mailbox</h3>
          <p class="card-desc">Each mailbox needs a Linux system user for Dovecot authentication:</p>
          <div class="cmd-block">
<span class="comment"># For each mailbox user</span>
<span class="cmd">sudo useradd -m -s /usr/sbin/nologin hello</span>
<span class="cmd">sudo passwd hello</span>
<span class="comment"># Set the same password as their NodeMail account</span>
          </div>

          <h3 style="font-size:13px;margin: 16px 0 8px;font-family:var(--font-mono);color:var(--text-dim);">4. Sync NodeMail emails to Maildir</h3>
          <p class="card-desc">Run this periodically (via cron) to export emails from MongoDB to Maildir format for Dovecot:</p>
          <div class="cmd-block">
<span class="comment"># Add to crontab: */5 * * * *</span>
<span class="cmd">cd /root/nodemail && node scripts/sync-maildir.js</span>
          </div>

          <h3 style="font-size:13px;margin: 16px 0 8px;font-family:var(--font-mono);color:var(--text-dim);">5. Open firewall ports</h3>
          <div class="cmd-block">
<span class="cmd">sudo ufw allow 993/tcp</span>  <span class="comment"># IMAP SSL</span>
<span class="cmd">sudo ufw allow <%= smtpRelayPort %>/tcp</span>  <span class="comment"># SMTP Relay</span>
          </div>

          <h3 style="font-size:13px;margin: 16px 0 8px;font-family:var(--font-mono);color:var(--text-dim);">6. SSL certificate for mail hostname</h3>
          <div class="cmd-block">
<span class="cmd">sudo certbot certonly --standalone -d <%= hostname %></span>
<span class="comment"># Or if nginx is running:</span>
<span class="cmd">sudo certbot certonly --nginx -d <%= hostname %></span>
          </div>

          <div class="guide-note" style="margin-top:16px;">
            <strong>Note:</strong> The outbound SMTP relay (port <%= smtpRelayPort %>) is built into NodeMail and requires no extra setup.
            Users authenticate with their NodeMail credentials and can send from any mailbox they're assigned to.
            For production, add TLS to the relay by placing it behind a TLS proxy or extending the config.
          </div>
        </div>

      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
  <script>
    function copyVal(id, btn) {
      const text = document.getElementById(id).textContent;
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
      });
    }

    function showTab(name, btn) {
      document.querySelectorAll('.client-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.client-tab').forEach(t => t.classList.remove('active'));
      document.getElementById('tab-' + name).classList.add('active');
      btn.classList.add('active');
    }

    function updateConfig() {
      const sel = document.getElementById('mailboxSelect');
      if (!sel) return;
      const email = sel.value;
      const tbEl = document.getElementById('tbEmail');
      if (tbEl) tbEl.textContent = email;
    }
    updateConfig();
  </script>
</body>
</html>
