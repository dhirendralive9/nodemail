<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NodeMail — Domains</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="app">
    <%- include('../partials/sidebar') %>

    <div class="main">
      <div class="toolbar">
        <span class="toolbar-title">&#127760; Domain Management</span>
      </div>

      <div class="settings-page">

        <% if (error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="success-msg"><%= success %></div>
        <% } %>

        <!-- Add domain -->
        <div class="settings-card">
          <h2>Add Domain</h2>
          <p class="card-desc">Add a domain to receive emails. You'll need access to the domain's DNS settings.</p>
          <form method="POST" action="/domains/add" class="inline-form">
            <input type="text" name="domain" placeholder="example.com" required>
            <button type="submit" class="btn btn-primary">Add Domain</button>
          </form>
        </div>

        <!-- Domain list -->
        <div class="settings-card">
          <h2>Your Domains</h2>

          <% if (domains.length === 0) { %>
            <p class="card-desc">No domains added yet. Add a domain above to get started.</p>
          <% } else { %>
            <table class="settings-table">
              <thead>
                <tr>
                  <th>Domain</th>
                  <th>MX</th>
                  <th>SPF</th>
                  <th>Status</th>
                  <th>Added</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% domains.forEach(function(d) { %>
                  <tr>
                    <td><strong><%= d.domain %></strong></td>
                    <td>
                      <span class="status-dot <%= d.mxConfigured ? 'green' : 'red' %>"></span>
                      <%= d.mxConfigured ? 'OK' : 'Missing' %>
                    </td>
                    <td>
                      <span class="status-dot <%= d.spfConfigured ? 'green' : 'red' %>"></span>
                      <%= d.spfConfigured ? 'OK' : 'Missing' %>
                    </td>
                    <td>
                      <% if (d.verified) { %>
                        <span class="badge-status verified">&#10003; Verified</span>
                      <% } else { %>
                        <span class="badge-status pending">Pending</span>
                      <% } %>
                    </td>
                    <td class="text-muted"><%= new Date(d.createdAt).toLocaleDateString() %></td>
                    <td class="action-cell">
                      <a href="/domains/<%= d._id %>/guide" class="btn btn-sm">&#128214; DNS Guide</a>
                      <form method="POST" action="/domains/<%= d._id %>/verify" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-primary">&#128269; Verify DNS</button>
                      </form>
                      <form method="POST" action="/domains/<%= d._id %>/delete" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Remove this domain?')">&#128465;</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>

        <!-- Quick info -->
        <div class="settings-card">
          <h2>Server Info</h2>
          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">Mail Hostname</span>
              <code><%= serverHostname %></code>
            </div>
            <div class="info-item">
              <span class="info-label">Inbound Mode</span>
              <code><%= process.env.INBOUND_MODE || 'smtp' %></code>
            </div>
            <div class="info-item">
              <span class="info-label">SMTP Port</span>
              <code><%= process.env.INBOUND_SMTP_PORT || 25 %></code>
            </div>
            <div class="info-item">
              <span class="info-label">Outbound SMTP</span>
              <code><%= process.env.SMTP_HOST %></code>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</body>
</html>
