<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NodeMail — Users</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= v %>">
</head>
<body>
  <div class="app">
    <%- include('../partials/sidebar') %>

    <div class="main">
      <div class="toolbar">
        <button class="sidebar-toggle" onclick="toggleSidebar()"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg></button>
        <span class="toolbar-title">User Management</span>
      </div>

      <div class="settings-page">

        <% if (error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="success-msg"><%= success %></div>
        <% } %>

        <!-- Add user -->
        <div class="settings-card">
          <h2>Add User</h2>
          <p class="card-desc">Create a login account. After creating, assign mailboxes in the <a href="/mailboxes">Mailboxes</a> page.</p>
          <form method="POST" action="/users/add">
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; margin-bottom:14px;">
              <div class="form-row" style="margin-bottom:0;">
                <label>Login Email</label>
                <input type="email" name="email" placeholder="user@example.com" required style="margin-bottom:0;">
              </div>
              <div class="form-row" style="margin-bottom:0;">
                <label>Password</label>
                <input type="password" name="password" placeholder="Strong password" required style="margin-bottom:0;">
              </div>
              <div class="form-row" style="margin-bottom:0;">
                <label>Display Name</label>
                <input type="text" name="name" placeholder="John Doe" style="margin-bottom:0;">
              </div>
            </div>
            <button type="submit" class="btn btn-primary">Create User</button>
          </form>
        </div>

        <!-- User list -->
        <div class="settings-card">
          <h2>Existing Users</h2>
          <% if (users.length === 0) { %>
            <p class="card-desc">No users yet.</p>
          <% } else { %>
            <table class="settings-table">
              <thead>
                <tr>
                  <th>Login Email</th>
                  <th>Name</th>
                  <th>Assigned Mailboxes</th>
                  <th>Created</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(function(u) { %>
                  <tr>
                    <td><strong><%= u.email %></strong></td>
                    <td><%= u.name || '\u2014' %></td>
                    <td>
                      <% if (u.mailboxes && u.mailboxes.length > 0) { %>
                        <% u.mailboxes.forEach(function(mb) { %>
                          <span class="badge-status verified" style="margin-right:4px;margin-bottom:4px;display:inline-block;"><%= mb.address %></span>
                        <% }); %>
                      <% } else { %>
                        <span style="color:var(--text-muted);font-size:12px;">None &mdash; <a href="/mailboxes">assign mailboxes</a></span>
                      <% } %>
                    </td>
                    <td class="text-muted"><%= new Date(u.createdAt).toLocaleDateString() %></td>
                    <td>
                      <form method="POST" action="/users/<%= u._id %>/delete" style="display:inline">
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this user and all their emails?')">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>

        <!-- How it works -->
        <div class="settings-card">
          <h2>Users vs Mailboxes</h2>
          <div class="card-desc" style="line-height:1.8;">
            <strong>Users</strong> are login accounts for the NodeMail web interface. A user logs in with their email and password.<br><br>
            <strong>Mailboxes</strong> are email addresses on your domains (e.g. <code>hello@yourdomain.com</code>). They handle inbound and outbound mail.<br><br>
            A user can be assigned to multiple mailboxes, and a mailbox can have multiple users assigned to it.
            Go to <a href="/mailboxes">Mailboxes</a> to create addresses and assign users.
          </div>
        </div>

      </div>
    </div>
  </div>
  <script src="/js/app.js?v=<%= v %>"></script>
</body>
</html>
