<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NodeMail — Mailboxes</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .mb-row {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      transition: background 0.08s;
    }
    .mb-row:last-child { border-bottom: none; }
    .mb-row:hover { background: var(--bg-hover); }
    .mb-addr {
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 500;
      color: var(--accent-h);
    }
    .mb-name {
      font-size: 11px;
      color: var(--text-muted);
      margin-left: 8px;
    }
    .mb-badges {
      display: flex;
      gap: 4px;
      align-items: center;
      flex-wrap: wrap;
    }
    .mb-badge {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 2px 6px;
      border-radius: 2px;
      white-space: nowrap;
    }
    .mb-badge.active { background: var(--green-dim); color: #86efac; }
    .mb-badge.disabled { background: var(--bg-hover); color: var(--text-muted); }
    .mb-badge.catchall { background: #1e1b4b; color: #a78bfa; }
    .mb-badge.fwd { background: var(--accent-dim); color: var(--accent-h); }
    .mb-badge.users { background: var(--bg-hover); color: var(--text-dim); }
    .mb-arrow {
      color: var(--text-muted);
      display: flex;
    }
    .mb-arrow svg { width: 14px; height: 14px; }
  </style>
</head>
<body>
  <div class="app">
    <%- include('../partials/sidebar') %>

    <div class="main">
      <div class="toolbar">
        <button class="sidebar-toggle" onclick="toggleSidebar()">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
        <span class="toolbar-title">Mailboxes</span>
        <span style="font-family:var(--font-mono);font-size:10px;color:var(--text-muted);margin-left:6px;"><%= mailboxes.length %></span>
      </div>

      <div class="settings-page">

        <% if (error) { %><div class="error-msg"><%= error %></div><% } %>
        <% if (success) { %><div class="success-msg"><%= success %></div><% } %>

        <!-- Create -->
        <div class="settings-card">
          <h2>Create Mailbox</h2>
          <% if (domains.length === 0) { %>
            <div class="error-msg">No verified domains. <a href="/domains">Add and verify a domain</a> first.</div>
          <% } else { %>
            <form method="POST" action="/mailboxes/add">
              <div style="display:flex; gap:6px; align-items:end; flex-wrap:wrap;">
                <div class="form-row" style="margin-bottom:0;flex:1;min-width:120px;">
                  <label>Address</label>
                  <input type="text" name="localPart" placeholder="hello" required style="margin-bottom:0;">
                </div>
                <div style="padding-bottom:6px; font-family:var(--font-mono); font-size:16px; color:var(--text-muted);">@</div>
                <div class="form-row" style="margin-bottom:0;flex:1;min-width:140px;">
                  <label>Domain</label>
                  <select name="domain" class="form-select" style="margin-bottom:0;">
                    <% domains.forEach(function(d) { %>
                      <option value="<%= d.domain %>"><%= d.domain %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="form-row" style="margin-bottom:0;min-width:120px;">
                  <label>Display Name</label>
                  <input type="text" name="displayName" placeholder="Optional" style="margin-bottom:0;">
                </div>
                <button type="submit" class="btn btn-primary" style="margin-bottom:1px;height:36px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                  Create
                </button>
              </div>
            </form>
          <% } %>
        </div>

        <!-- Mailbox list -->
        <div class="settings-card" style="padding:0;overflow:hidden;">
          <% if (mailboxes.length === 0) { %>
            <div style="padding:24px;text-align:center;color:var(--text-muted);font-family:var(--font-mono);font-size:12px;">
              No mailboxes yet. Create one above.
            </div>
          <% } else { %>
            <% mailboxes.forEach(function(mb) { %>
              <div class="mb-row" onclick="window.location='/mailboxes/<%= mb._id %>'">
                <div>
                  <span class="mb-addr"><%= mb.address %></span>
                  <% if (mb.displayName && mb.displayName !== mb.localPart) { %>
                    <span class="mb-name"><%= mb.displayName %></span>
                  <% } %>
                </div>
                <div class="mb-badges">
                  <% if (mb.active) { %>
                    <span class="mb-badge active">Active</span>
                  <% } else { %>
                    <span class="mb-badge disabled">Disabled</span>
                  <% } %>
                  <% if (mb.catchAll) { %>
                    <span class="mb-badge catchall">Catch-all</span>
                  <% } %>
                  <% if (mb.forwardEnabled) { %>
                    <span class="mb-badge fwd">Fwd</span>
                  <% } %>
                  <% if (mb.assignedUsers && mb.assignedUsers.length > 0) { %>
                    <span class="mb-badge users"><%= mb.assignedUsers.length %> user<%= mb.assignedUsers.length > 1 ? 's' : '' %></span>
                  <% } %>
                  <span class="mb-arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                  </span>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>

      </div>
    </div>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
